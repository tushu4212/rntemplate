source "https://rubygems.org"

# Use Ruby 3.1+ (e.g. brew install ruby). System Ruby 2.6 fails TLS, ffi, and Bundler in this stack.
ruby ">= 3.1.0"

# Prebuilt darwin ffis (avoid broken source builds on new Xcode / macOS).
gem "ffi", ">= 1.17.0", "< 1.18"

# Exclude problematic versions of cocoapods and activesupport that causes build failures.
gem "cocoapods", ">= 1.13", "!= 1.15.0", "!= 1.15.1"
gem "activesupport", ">= 6.1.7.5", "!= 7.1.0"
gem "xcodeproj", "< 1.26.0"
gem "concurrent-ruby", "< 1.3.4"

# Ruby 3.4+ may need these as gems.
gem "bigdecimal"
gem "logger"
gem "benchmark"
gem "mutex_m"
gem "nkf"
